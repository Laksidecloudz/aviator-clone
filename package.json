{
  "name": "aviator-clone",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "knip": "knip",
    "deploy:web": "npm run build",
    "electron:build": "ELECTRON_BUILD=true npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.worldstarbetting.aviator",
    "productName": "Aviator - WorldStar Betting",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "public/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "portable": {
      "artifactName": "Aviator-Windows.exe"
    }
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jscpd": "^4.0.8",
    "knip": "^6.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1"
  }
}
